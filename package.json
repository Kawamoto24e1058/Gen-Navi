    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "vite": "^5.4.11"
  },
  "type": "module",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "leaflet": "^1.9.4",
    "lucide-svelte": "^0.460.0"
  },
  "engines": {
    "node": "20.x"
  }

{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"moduleResolution": "bundler",
		"module": "esnext",
		"target": "esnext",
		"checkJs": true,
		"allowJs": true,
		"strict": true,
		"noImplicitAny": false,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"sourceMap": true
	}
}